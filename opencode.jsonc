{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": {
      "clients/**": "allow",
      "_template/**": "allow",
      "tools/**": "allow",
      "*.md": "allow",
      "**": "ask"
    },
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "mkdir -p *": "allow",
      "cp *": "allow",
      "test -d *": "allow",
      "test -f *": "allow",
      "find clients/* *": "allow",
      "find _template/* *": "allow"
    }
  }
}
